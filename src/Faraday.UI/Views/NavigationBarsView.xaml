<UserControl x:Class="Faraday.UI.Views.NavigationBarsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Faraday.UI.Views"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    
    <Grid Background="#FF2D2D30" Height="50" VerticalAlignment="Top">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" /> <!-- (0)Dashboard-->
            <ColumnDefinition Width="Auto" /> <!-- (1)Investing -->
            <ColumnDefinition Width="Auto" /> <!-- (2)Debt -->
            <ColumnDefinition Width="Auto" /> <!-- (3)Assets -->
            <ColumnDefinition Width="Auto" />  <!-- (4)Tools -->
            <ColumnDefinition Width="*" />    <!-- (5)Spacer -->
            <ColumnDefinition Width="Auto" /> <!-- (6)Settings -->
        </Grid.ColumnDefinitions>

        <!-- Dashboard Button -->
        <Button x:Name="DashboardButton" Grid.Column="0"
                Style="{StaticResource NavbarButtonStyle}"
                Content="Dashboard"
                Command="{Binding NavbarSelectionCommand}"
                CommandParameter="Dashboard" />
        
        <!-- ~1~ Investing Button @1@ -->
        <!-- <Button x:Name="InvestingButton" Content="Investing" Classes="Navbar" Grid.Column="1" -->
        <!--         Command="{Binding NavbarSelectionCommand }" CommandParameter="Investing"/> -->
        <!-- -->
        <!-- ~1~ Debt Button @1@ -->
        <!-- <Button x:Name="DebtButton" Content="Debt" Classes="Navbar" Grid.Column="2" -->
        <!--         Command="{Binding NavbarSelectionCommand }" CommandParameter="Debt"/> -->
        <!-- -->
        <!-- ~1~ Assets Button @1@ -->
        <!-- <Button x:Name="AssetsButton" Content="Assets" Classes="Navbar" Grid.Column="3" -->
        <!--         Command="{Binding NavbarSelectionCommand }" CommandParameter="Assets"/> -->
        <!-- -->
        <!-- ~1~ Tools Dropdown @1@ -->
        <!-- <Button x:Name="ToolsButton" Content="Tools" Classes="Navbar" -->
        <!--         Grid.Column="4" Flyout="{StaticResource ToolsFlyout}"/> -->
        <!-- -->
        <!-- ~1~ Settings Button @1@ -->
        <Button x:Name="SettingsButton" Grid.Column="6"
                Style="{StaticResource NavbarButtonStyle}"
                Content="Settings"
                Command="{Binding NavbarSelectionCommand}" 
                CommandParameter="Settings">
        </Button>
    </Grid>
</UserControl>