<UserControl x:Class="Faraday.UI.Views.DashboardViews.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Faraday.UI.Views.DashboardViews"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    
    <Grid Margin="10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Overview Panel -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Disabled">
            <Border CornerRadius="20" Background="AliceBlue" Width="200" Margin="5,0,5,0">
                <StackPanel>
                    <!-- Account Control Button -->
                    <Button Content="All Accounts" Margin="10" HorizontalAlignment="Stretch"
                            Command="{Binding AllAccountsButtonCommand}" />
                    
                    <!-- Spacer -->
                    <Rectangle Width="140" Height="1" Fill="Gray" HorizontalAlignment="Center" />
                    
                    <!-- Accounts -->
                    <ItemsControl ItemsSource="{Binding ActiveAccounts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="10" HorizontalAlignment="Stretch"
                                        Command="{Binding DataContext.SwitchCurrentAccountCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding Name}">
                                    <TextBlock>
                                        <Run Text="{Binding Name}" />
                                        <Run Text=" | $" />
                                        <Run Text="{Binding Balance}" />
                                    </TextBlock>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <Button Content="+ Add an Account" Margin="10" HorizontalAlignment="Stretch"
                            Command="{Binding OpenAddAccountWindowCommand}" />
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Divider -->
        <Rectangle Grid.Column="1" Fill="Gray" Width="1" Margin="5,0" />

        <!-- Widget/Account Panel -->
        <ContentControl prism:RegionManager.RegionName="WidgetAccountRegion" Grid.Column="2" />
    </Grid>
</UserControl>
