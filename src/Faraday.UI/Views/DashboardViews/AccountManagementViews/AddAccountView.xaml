<UserControl x:Class="Faraday.UI.Views.DashboardViews.AccountManagementViews.AddAccountView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d" Height="450" Width="800">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Account Name -->
        <Label Grid.Column="0" Grid.Row="0" Content="Name"
               Margin="20,20,0,0" />
        <TextBox Grid.Column="1" Grid.Row="0" Height="25" Text="{Binding EnteredName}"
                 Margin="0,20,10,0" Width="150" />

        <!-- Account Currency -->
        <Label Grid.Column="0" Grid.Row="1" Content="Currency" Height="25"
               Margin="20,0,0,0" />
        <ComboBox Grid.Column="1" Grid.Row="1" Height="25"
                  Margin="0,10,10.35,0"
                  ItemsSource="{Binding CurrencyOptions}"
                  SelectedItem="{Binding SelectedCurrency}" />

        <!-- Account Institution -->
        <Label Grid.Column="0" Grid.Row="2" Content="Institution" Height="25"
               Margin="20,0,0,0" />
        <ComboBox Grid.Column="1" Grid.Row="2" Height="25"
                  Margin="0,10,10.35,0"
                  ItemsSource="{Binding InstitutionOptions}"
                  SelectedItem="{Binding SelectedInstitution}" />

        <!-- Account Type -->
        <Label Grid.Column="0" Grid.Row="3" Content="Type" Height="25"
               Margin="20,0,0,0" />
        <ComboBox Grid.Column="1" Grid.Row="3" Height="25"
                  Margin="0,10,10.35,0"
                  ItemsSource="{Binding TypeOptions}"
                  SelectedItem="{Binding SelectedType}" />

        <!-- Data Insertion Method -->
        <TabControl Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="4"
                    Margin="20" HorizontalContentAlignment="Stretch"
                    SelectedIndex="{Binding SelectedMode, Mode=TwoWay}">

            <!-- CSV -->
            <TabItem Header="Upload CSV">
                <StackPanel
                    Visibility="{Binding SelectedMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=CSV}">
                    <TextBlock Text="Upload CSV file" HorizontalAlignment="Center" Margin="5" />
                    <Button Content="Browse..." HorizontalAlignment="Center" Margin="5"
                            Command="{Binding UploadCSVFileCommand}" />
                </StackPanel>
            </TabItem>

            <!-- Manual -->
            <TabItem Header="Manual">
                <Grid
                    Visibility="{Binding SelectedMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Manual}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Ending Balance -->
                    <Label Grid.Column="0" Grid.Row="0" Content="Ending Balance" Margin="10"
                           HorizontalAlignment="Center" />
                    <TextBox Grid.Column="1" Grid.Row="0" Text="{Binding EndingBalance}" Margin="10"
                             HorizontalAlignment="Center" Width="100"
                             PreviewTextInput="NumberTextBox_PreviewTextInput"
                             DataObject.Pasting="NumberTextBox_Pasting" />

                    <!-- Ending Date -->
                    <Label Grid.Column="0" Grid.Row="1" Content="Ending Date" Margin="10" HorizontalAlignment="Center" />
                    <DatePicker Grid.Column="1" Grid.Row="1" SelectedDate="{Binding SelectedDate}"
                                Margin="15" HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Preview -->
        <DataGrid x:Name="PreviewDataGrid" Grid.Column="2" Grid.Row="0" Margin="5"
                  BorderBrush="Gray" BorderThickness="2" Grid.RowSpan="5"
                  ItemsSource="{Binding CsvData}"
                  DataContextChanged="PreviewDataGrid_OnDataContextChanged" />

        <!-- Finish Button -->
        <Button Grid.Column="2" Grid.Row="5" Content="Finish" Margin="10"
                HorizontalAlignment="Right" Padding="15,5"
                Command="{Binding FinishButtonCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" />
    </Grid>
</UserControl>